[
  {
    "type": "MOD_INFO",
    "id": "megacity_mod",
    "name": "Megacity",
    "authors": [ "Renech" ],
    "maintainers": [ "Worm Girl" ],
    "description": "The world is entirely covered by a single, unending city.",
    "category": "total_conversion",
    "dependencies": [ "tlg" ]
  },
  {
    "type": "EXTERNAL_OPTION",
    "name": "DEFAULT_REGION",
    "stype": "string_input",
    "value": "mega_mega_city"
  },
  {
    "id": "FAKE_UNUSED_FLAG",
    "type": "json_flag",
    "name": "",
    "//COMMENT": "Fake flag used for an empty whitelist."
  },
  {
    "type": "overmap_special",
    "id": "Evac Shelter",
    "copy-from": "Evac Shelter",
    "//COMMENT": "Oops! Not so unused now, are you? Well we need to spawn somewhere, so this will have to do. For now.",
    "extend": { "flags": [ "FAKE_UNUSED_FLAG" ] }
  },
  {
    "type": "region_settings",
    "id": "mega_mega_city",
    "copy-from": "default",
    "place_swamps": false,
    "rivers": null,
    "ocean": null,
    "forests": null,
    "lakes": null,
    "highways": null,
    "cities": "mega_mega_city_settings",
    "feature_flag_settings": { "extend": { "whitelist": [ "FAKE_UNUSED_FLAG" ] } }
  },
  {
    "type": "SCENARIO_BLACKLIST",
    "subtype": "whitelist",
    "scenarios": [ "evacuee" ]
  },
  {
    "type": "EXTERNAL_OPTION",
    "name": "MEGACITY",
    "//": "If true, mapgen will be overwritten to place several large overlapping cities on every overmap. Intended for use only in the megacity mod, using it in other circumstances may cause strange behavior.",
    "stype": "bool",
    "value": true
  },
  {
    "type": "region_settings_city",
    "id": "mega_mega_city_settings",
    "copy-from": "default",
    "shop_radius": 200,
    "shop_sigma": 0,
    "park_radius": 0,
    "park_sigma": 0
  }
]
