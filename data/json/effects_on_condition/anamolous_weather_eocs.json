[
  {
    "type": "effect_on_condition",
    "id": "EOC_FALLOUT_WARN_OR_CAUSE_RECURRING",
    "recurrence": [
      { "global_val": "fallout_min_recurrence", "default": "3 days" },
      { "global_val": "fallout_max_recurrence", "default": "100 days" }
    ],
    "global": true,
    "effect": { "run_eocs": "EOC_CAUSE_FALLOUT" }
  },
  {
    "type": "effect_on_condition",
    "id": "EOC_CAUSE_FALLOUT",
    "global": true,
    "condition": {
      "and": [
        { "not": { "or": [ { "is_weather": "fallout" }, { "math": [ "cause_fallout == 1" ] } ] } },
        {
          "or": [
            { "is_weather": "clear" },
            { "is_weather": "sunny" },
            { "is_weather": "fog" },
            { "is_weather": "mist" },
            { "is_weather": "cloudy" }
          ]
        }
      ]
    },
    "effect": [
      { "math": [ "cause_fallout = 1" ] },
      "next_weather",
      { "run_eocs": [ "EOC_CAUSE_FALLOUT_MESSAGE" ] },
      {
        "run_eocs": "EOC_CANCEL_FALLOUT",
        "time_in_future": [
          { "global_val": "fallout_min_length", "default": "4 hours" },
          { "global_val": "fallout_max_length", "default": "48 hours" }
        ]
      }
    ]
  },
  {
    "type": "effect_on_condition",
    "id": "EOC_CAUSE_FALLOUT_MESSAGE",
    "global": true,
    "condition": { "and": [ "u_is_outside" ] },
    "effect": [
      {
        "u_message": "The wind carries the scent of burning wood and plastic, heralding the arrival of unnaturally dark clouds which scatter ash across the landscape, almost like black snow…",
        "type": "bad",
        "popup": true
      }
    ]
  },
  {
    "type": "effect_on_condition",
    "id": "EOC_FALLOUT_CHECK",
    "recurrence": [ "5 minutes", "10 minutes" ],
    "global": true,
    "condition": { "math": [ "cause_fallout == 1" ] },
    "deactivate_condition": { "math": [ "cause_fallout != 1" ] },
    "effect": "next_weather"
  },
  {
    "type": "effect_on_condition",
    "id": "EOC_FALLOUT_ACTIVE",
    "recurrence": [ "1 minutes", "10 minutes" ],
    "global": true,
    "condition": { "is_weather": "fallout" },
    "deactivate_condition": { "not": { "is_weather": "fallout" } },
    "effect": [ { "run_eocs": "EOC_FALLOUT_FIELD" } ]
  },
  {
    "type": "effect_on_condition",
    "id": "EOC_FALLOUT_FIELD",
    "effect": [ { "u_set_field": "fd_fallout", "outdoor_only": true } ]
  },
  {
    "type": "effect_on_condition",
    "id": "EOC_CANCEL_FALLOUT",
    "global": true,
    "condition": { "or": [ { "is_weather": "fallout" }, { "math": [ "cause_fallout == 1" ] } ] },
    "effect": [ { "math": [ "cause_fallout = 0" ] }, "next_weather" ]
  },
  {
    "type": "effect_on_condition",
    "id": "EOC_CANCEL_FALLOUT_MESSAGE",
    "global": true,
    "condition": { "and": [ "u_is_outside" ] },
    "effect": [ { "u_message": "The ash has stopped falling, and the clouds no longer seem so ominous.", "type": "good" } ]
  }
]
